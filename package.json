    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.10",
    "class-variance-authority": "^0.7.1",
