# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (NextAuth.js) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Auth mode — controls which sign-in methods appear on the login page.
#   credentials  — email/password form only (default for local dev)
#   sso          — Microsoft Entra ID SSO button only
#   both         — show both options side-by-side
AUTH_MODE="credentials"

# ── SSO — Microsoft Entra ID (Azure AD) ─────────────────────────────────────
# Required when AUTH_MODE is "sso" or "both".
# Register an app in Azure Portal → App registrations → add a Web redirect URI:
#   http://localhost:3000/api/auth/callback/microsoft-entra-id  (dev)
#   https://yourdomain.com/api/auth/callback/microsoft-entra-id (prod)
AUTH_ENTRA_CLIENT_ID=""
AUTH_ENTRA_CLIENT_SECRET=""
AUTH_ENTRA_TENANT_ID=""    # your Azure tenant ID, or "common" for multi-tenant

# ── AWS S3 (course content storage) ─────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-key-id"
AWS_SECRET_ACCESS_KEY="your-secret"
S3_BUCKET_NAME="kirby-learning-academy-dev"

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="your-resend-key"
EMAIL_FROM="noreply@kirbylearningacademy.com"


