// Kirby Learning Academy — Prisma Schema
// Phase 11: Automation & Notifications

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7+)
}

// ── Tenants (business units / multi-tenancy) ────────────────────────────────
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique  // used in subdomain / header routing
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  businessUnits BusinessUnit[]
  departments Department[]
  locations   Location[]
  jobTitles   JobTitle[]
  hrisSyncLogs HrisSyncLog[]
  courses      Course[]
  enrollments  Enrollment[]
  learningPaths LearningPath[]
  curricula    Curriculum[]
  assessments  StandaloneAssessment[]
  skills        Skill[]
  skillCategories SkillCategory[]
  certifications       Certification[]
  complianceRequirements ComplianceRequirement[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  jobSchedules         JobSchedule[]

  @@map("tenants")
}

// ── Org Structure ────────────────────────────────────────────────────────────
model BusinessUnit {
  id          String   @id @default(cuid())
  name        String
  code        String?
  tenantId    String
  parentId    String?  // self-referential for nested business units
  sortOrder   Int      @default(0)
  hrisId      String?  // external HRIS system identifier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  parent      BusinessUnit? @relation("BusinessUnitHierarchy", fields: [parentId], references: [id])
  children    BusinessUnit[] @relation("BusinessUnitHierarchy")
  departments Department[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@map("business_units")
}

model Department {
  id             String   @id @default(cuid())
  name           String
  code           String?
  tenantId       String
  businessUnitId String?
  sortOrder      Int      @default(0)
  hrisId         String?  // external HRIS system identifier
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  users                User[]
  curriculumAssignments CurriculumAssignment[]
  assessmentAssignments AssessmentAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([businessUnitId])
  @@map("departments")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String?
  country   String   @default("US")
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  users     User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("locations")
}

model JobTitle {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  users     User[]
  skillRequirements RoleSkillRequirement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("job_titles")
}

// ── Users ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  displayName   String?
  avatarUrl     String?
  passwordHash  String?   // null for SSO-only accounts
  isActive      Boolean   @default(true)
  isContractor  Boolean   @default(false)  // contractor / external flag
  hireDate      DateTime?
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  locationId    String?
  location      Location?   @relation(fields: [locationId], references: [id])
  jobTitleId    String?
  jobTitle      JobTitle?   @relation(fields: [jobTitleId], references: [id])
  businessUnitId String?
  businessUnit  BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  // HRIS sync fields
  hrisId        String?   // identifier in the HRIS system
  hrisSource    String?   // "workday" | "successfactors" | "csv"
  lastHrisSyncAt DateTime?
  terminatedAt  DateTime? // set on HRIS termination; triggers deactivation

  roles         UserRole[]
  sessions      Session[]
  accounts      Account[]  // OAuth / SAML providers (NextAuth)
  passwordResets PasswordResetToken[]
  createdCourses Course[]        @relation("CourseCreator")
  uploadedVersions CourseVersion[] @relation("VersionUploader")
  enrollments           Enrollment[]           @relation("EnrolledUser")
  assignedEnrollments   Enrollment[]           @relation("AssignedBy")
  curriculumAssignments CurriculumAssignment[] @relation("UserCurriculumAssignments")
  assignedCurricula     CurriculumAssignment[] @relation("CurriculumAssignedBy")
  createdAssessments    StandaloneAssessment[] @relation("AssessmentCreator")
  assessmentAttempts    AssessmentAttempt[]    @relation("UserAssessmentAttempts")
  assessmentAssignments AssessmentAssignment[] @relation("UserAssessmentAssignments")
  assignedAssessments   AssessmentAssignment[] @relation("AssessmentAssignedBy")
  userSkills            UserSkill[]            @relation("UserSkills")
  endorsedSkills        UserSkill[]            @relation("SkillEndorser")
  certificationRecords  CertificationRecord[]  @relation("UserCertRecords")
  issuedCertRecords     CertificationRecord[]  @relation("CertIssuedBy")
  auditActions          AuditLog[]             @relation("AuditActor")
  notifications         Notification[]         @relation("UserNotifications")
  notificationPrefs     NotificationPreference[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ── Roles & Permissions ──────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  name        String   @unique  // SUPER_ADMIN | TENANT_ADMIN | COMPLIANCE_OFFICER | MANAGER | INSTRUCTOR | EMPLOYEE | CONTRACTOR
  description String?
  createdAt   DateTime @default(now())

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

// ── Sessions (NextAuth database sessions) ───────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ── OAuth / SAML Accounts (NextAuth) ────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // "oauth" | "saml" | "credentials"
  provider          String  // "azure-ad" | "okta" | "credentials"
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ── Verification Tokens (email / password reset) ────────────────────────────
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Password Reset Tokens ────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ── HRIS Sync Logs ───────────────────────────────────────────────────────────
model HrisSyncLog {
  id          String   @id @default(cuid())
  tenantId    String
  source      String   // "workday" | "successfactors" | "csv"
  status      String   // "running" | "success" | "failed"
  recordsIn   Int      @default(0)
  created     Int      @default(0)
  updated     Int      @default(0)
  deactivated Int      @default(0)
  errors      Json?    // array of error messages
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([startedAt])
  @@map("hris_sync_logs")
}

// ── Course Publishing ────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Course {
  id                   String       @id @default(cuid())
  tenantId             String
  title                String
  description          String?      @db.Text
  category             String?
  objectives           String[]     // auto-populated from manifest
  duration             Int?         // estimated minutes
  thumbnailUrl         String?
  targetAudience       String?      @db.Text
  complianceTags       String[]     // e.g. ["OSHA","USCG","Maritime"]
  isContractorVisible  Boolean      @default(false)
  status               CourseStatus @default(DRAFT)
  activeVersionId      String?      @unique
  createdById          String
  archivedAt           DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  createdBy     User            @relation("CourseCreator", fields: [createdById], references: [id])
  activeVersion CourseVersion?  @relation("ActiveVersion", fields: [activeVersionId], references: [id])
  versions      CourseVersion[] @relation("CourseVersions")
  tags               CourseTag[]
  languages          CourseLanguage[]
  enrollments        Enrollment[]
  learningPathCourses LearningPathCourse[]
  remediationFor     StandaloneAssessment[]
  courseSkills       CourseSkill[]
  renewalFor         Certification[]        @relation("CertRenewalCourse")

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("courses")
}

model CourseVersion {
  id               String   @id @default(cuid())
  courseId         String
  versionNumber    Int      // 1, 2, 3, ...
  s3Prefix         String   // e.g. "courses/clxxx/v1/"
  manifestSnapshot Json     // parsed _course_manifest.json at upload time
  originalFileName String?
  fileSizeBytes    Int?
  uploadedById     String
  uploadedAt       DateTime @default(now())

  course       Course       @relation("CourseVersions", fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation("VersionUploader", fields: [uploadedById], references: [id])
  activeFor    Course?      @relation("ActiveVersion")
  enrollments  Enrollment[]

  @@unique([courseId, versionNumber])
  @@index([courseId])
  @@map("course_versions")
}

model CourseTag {
  id       String @id @default(cuid())
  courseId String
  tag      String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, tag])
  @@index([courseId])
  @@map("course_tags")
}

model CourseLanguage {
  id        String  @id @default(cuid())
  courseId  String
  language  String  // ISO 639-1 e.g. "en", "es"
  isDefault Boolean @default(false)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, language])
  @@map("course_languages")
}

// ── Enrollment & Learning Delivery ──────────────────────────────────────────

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PASSED
  FAILED
  EXPIRED
}

model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  courseVersionId String?          // which version was active at enrollment
  tenantId        String
  status          EnrollmentStatus @default(NOT_STARTED)
  dueDate         DateTime?
  assignedById    String?          // null when self-enrolled
  selfEnrolled    Boolean          @default(false)
  startedAt       DateTime?        // first launch
  completedAt     DateTime?        // when status reached PASSED/FAILED
  score           Float?           // percentage 0–100
  passed          Boolean?
  attempts        Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user          User          @relation("EnrolledUser", fields: [userId], references: [id])
  course        Course        @relation(fields: [courseId], references: [id])
  courseVersion CourseVersion? @relation(fields: [courseVersionId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  assignedBy    User?         @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, courseId])   // one active enrollment per course per user
  @@index([userId])
  @@index([courseId])
  @@index([tenantId])
  @@index([status])
  @@map("enrollments")
}

// ── Learning Paths & Curricula ───────────────────────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  courses   LearningPathCourse[]
  curricula CurriculumPath[]

  @@index([tenantId])
  @@map("learning_paths")
}

model LearningPathCourse {
  id                   String  @id @default(cuid())
  learningPathId       String
  courseId             String
  order                Int     @default(0)
  isRequired           Boolean @default(true)
  prerequisiteCourseId String? // must have PASSED this courseId before launching this course

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id])

  @@unique([learningPathId, courseId])
  @@index([learningPathId])
  @@map("learning_path_courses")
}

model Curriculum {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  paths       CurriculumPath[]
  assignments CurriculumAssignment[]

  @@index([tenantId])
  @@map("curricula")
}

model CurriculumPath {
  id             String @id @default(cuid())
  curriculumId   String
  learningPathId String
  order          Int    @default(0)

  curriculum   Curriculum   @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [learningPathId], references: [id])

  @@unique([curriculumId, learningPathId])
  @@index([curriculumId])
  @@map("curriculum_paths")
}

model CurriculumAssignment {
  id           String    @id @default(cuid())
  curriculumId String
  tenantId     String
  // Target: one of these will be set
  roleName     String?   // e.g. "EMPLOYEE" — matches Role.name
  departmentId String?
  userId       String?
  dueDate      DateTime?
  assignedAt   DateTime  @default(now())
  assignedById String?

  curriculum Curriculum  @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  user       User?       @relation("UserCurriculumAssignments", fields: [userId], references: [id])
  assignedBy User?       @relation("CurriculumAssignedBy", fields: [assignedById], references: [id])

  @@index([curriculumId])
  @@index([userId])
  @@index([departmentId])
  @@index([tenantId])
  @@map("curriculum_assignments")
}

// ── Standalone Assessments & Attestations ───────────────────────────────────

enum AssessmentType {
  QUIZ
  ATTESTATION
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTI_SELECT
  ATTESTATION
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  PASSED
  FAILED
  ABANDONED
}

model StandaloneAssessment {
  id                  String           @id @default(cuid())
  tenantId            String
  title               String
  description         String?          @db.Text
  type                AssessmentType   @default(QUIZ)
  status              AssessmentStatus @default(DRAFT)
  passingScore        Int              @default(80)  // percentage 0–100
  maxAttempts         Int?             // null = unlimited
  timeLimitMinutes    Int?             // null = no time limit
  randomizeQuestions  Boolean          @default(false)
  questionsPerAttempt Int?             // null = all questions
  remediationCourseId String?          // on fail: recommend/auto-assign this course
  createdById         String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  createdBy         User                   @relation("AssessmentCreator", fields: [createdById], references: [id])
  remediationCourse Course?                @relation(fields: [remediationCourseId], references: [id])
  questions         Question[]
  assignments       AssessmentAssignment[]
  attempts          AssessmentAttempt[]

  @@index([tenantId])
  @@index([status])
  @@map("standalone_assessments")
}

model Question {
  id           String       @id @default(cuid())
  assessmentId String
  type         QuestionType
  text         String       @db.Text  // question text or attestation statement
  explanation  String?      @db.Text  // shown after answer reveal
  points       Int          @default(1)
  order        Int          @default(0)
  tags         String[]     // for question bank tagging

  assessmentRel StandaloneAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options       QuestionOption[]
  answers       AttemptAnswer[]

  @@index([assessmentId])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model AssessmentAssignment {
  id           String    @id @default(cuid())
  assessmentId String
  tenantId     String
  userId       String?
  roleName     String?
  departmentId String?
  dueDate      DateTime?
  assignedAt   DateTime  @default(now())
  assignedById String?

  assessment  StandaloneAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user        User?                @relation("UserAssessmentAssignments", fields: [userId], references: [id])
  assignedBy  User?                @relation("AssessmentAssignedBy", fields: [assignedById], references: [id])
  department  Department?          @relation(fields: [departmentId], references: [id])

  @@index([assessmentId])
  @@index([userId])
  @@map("assessment_assignments")
}

model AssessmentAttempt {
  id           String        @id @default(cuid())
  assessmentId String
  userId       String
  tenantId     String
  status       AttemptStatus @default(IN_PROGRESS)
  score        Float?        // percentage 0–100
  passed       Boolean?
  startedAt    DateTime      @default(now())
  submittedAt  DateTime?
  expiresAt    DateTime?     // set when timeLimitMinutes is configured

  assessment StandaloneAssessment @relation(fields: [assessmentId], references: [id])
  user       User                 @relation("UserAssessmentAttempts", fields: [userId], references: [id])
  answers    AttemptAnswer[]

  @@index([assessmentId])
  @@index([userId])
  @@index([tenantId])
  @@map("assessment_attempts")
}

model AttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionIds String[] // IDs of chosen QuestionOption(s)
  acknowledged      Boolean  @default(false)  // for ATTESTATION type
  isCorrect         Boolean?
  pointsEarned      Float    @default(0)
  createdAt         DateTime @default(now())

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("attempt_answers")
}

// ── Skills Matrix & Competency Tracking (Phase 8) ────────────────────────────

model SkillCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  skills Skill[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("skill_categories")
}

model Skill {
  id          String  @id @default(cuid())
  tenantId    String
  categoryId  String?
  name        String
  description String? @db.Text
  // Proficiency levels: stored as labels e.g. ["Awareness","Developing","Proficient","Advanced","Expert"]
  // Index 0 = lowest, last = highest. Default 5-level 1-indexed scale.
  levelLabels String[] // ordered labels for levels 1..N; empty = use numeric 1–5

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  category         SkillCategory?         @relation(fields: [categoryId], references: [id])
  userSkills       UserSkill[]
  courseSkills     CourseSkill[]
  roleRequirements RoleSkillRequirement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([categoryId])
  @@map("skills")
}

// Awarded proficiency a user has for a skill
model UserSkill {
  id           String   @id @default(cuid())
  userId       String
  skillId      String
  level        Int      // 1-based index into Skill.levelLabels (or 1–5 if custom empty)
  source       String   // "manual" | "course_completion" | "assessment"
  sourceId     String?  // enrollment/attempt id that granted this
  endorsedById String?  // manager/instructor who manually endorsed
  notes        String?
  grantedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User   @relation("UserSkills", fields: [userId], references: [id], onDelete: Cascade)
  skill      Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  endorsedBy User?  @relation("SkillEndorser", fields: [endorsedById], references: [id])

  @@unique([userId, skillId])   // one record per user+skill (upsert on new grant)
  @@index([userId])
  @@index([skillId])
  @@map("user_skills")
}

// Skills granted on completing a course
model CourseSkill {
  id         String @id @default(cuid())
  courseId   String
  skillId    String
  levelGrant Int    @default(1) // minimum level awarded on completion

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
  @@index([courseId])
  @@map("course_skills")
}

// Minimum required skill level for a job title
model RoleSkillRequirement {
  id           String @id @default(cuid())
  jobTitleId   String
  skillId      String
  requiredLevel Int   @default(1)

  jobTitle JobTitle @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobTitleId, skillId])
  @@index([jobTitleId])
  @@map("role_skill_requirements")
}

// ── Compliance & Certification (Phase 9) ────────────────────────────────────

enum CertFramework {
  OSHA
  USCG
  EPA
  ISM_CODE
  STCW
  DOT
  INTERNAL
}

enum CertStatus {
  PENDING
  VALID
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
}

enum CertType {
  INITIAL
  RENEWAL
  RECERTIFICATION
}

enum RequirementScope {
  JOB_TITLE
  DEPARTMENT
  LOCATION
  BUSINESS_UNIT
}

enum AuditAction {
  CERT_ISSUED
  CERT_RENEWED
  CERT_EXPIRED
  CERT_SUSPENDED
  CERT_UPLOADED
  CERT_REVOKED
  REQUIREMENT_CREATED
  REQUIREMENT_UPDATED
  REQUIREMENT_DELETED
}

// Certification type definition (the template, not a user's record)
model Certification {
  id                String        @id @default(cuid())
  tenantId          String
  name              String
  description       String?       @db.Text
  framework         CertFramework @default(INTERNAL)
  type              CertType      @default(INITIAL)
  validityDays      Int?          // null = no expiry / evergreen
  renewalWindowDays Int           @default(90) // days before expiry to flag EXPIRING_SOON
  renewalCourseId   String?       // course auto-assigned on approaching renewal
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  renewalCourse      Course?                 @relation("CertRenewalCourse", fields: [renewalCourseId], references: [id])
  records            CertificationRecord[]
  requirements       ComplianceRequirement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("certifications")
}

// A user's instance of a certification
model CertificationRecord {
  id              String     @id @default(cuid())
  certificationId String
  userId          String
  tenantId        String
  status          CertStatus @default(PENDING)
  issuedAt        DateTime?
  expiresAt       DateTime?
  renewedFromId   String?    // previous CertificationRecord.id
  source          String     // "manual" | "course_completion" | "upload" | "attestation"
  sourceId        String?    // enrollmentId or attemptId
  documentUrl     String?    // uploaded cert document
  notes           String?    @db.Text
  issuedById      String?
  ipAddress       String?    // for digital sign-off attestations
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  certification Certification       @relation(fields: [certificationId], references: [id])
  user          User                @relation("UserCertRecords", fields: [userId], references: [id])
  issuedBy      User?               @relation("CertIssuedBy", fields: [issuedById], references: [id])
  history       CertificationHistory[]
  renewedFrom   CertificationRecord?  @relation("CertRenewal", fields: [renewedFromId], references: [id])
  renewals      CertificationRecord[] @relation("CertRenewal")

  @@index([certificationId])
  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@map("certification_records")
}

// Immutable audit trail for a cert record
model CertificationHistory {
  id          String      @id @default(cuid())
  recordId    String
  fromStatus  CertStatus?
  toStatus    CertStatus
  changedAt   DateTime    @default(now())
  changedById String?
  reason      String?
  ipAddress   String?

  record CertificationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("certification_history")
}

// Compliance rules: "job X must hold cert Y"
model ComplianceRequirement {
  id              String           @id @default(cuid())
  tenantId        String
  certificationId String
  scope           RequirementScope
  scopeId         String?          // jobTitleId | departmentId | locationId | businessUnitId
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([certificationId])
  @@map("compliance_requirements")
}

// Platform-wide immutable audit log
model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  action     AuditAction
  actorId    String?     // userId of person performing action
  targetId   String?     // userId being acted on
  entityId   String?     // e.g. certificationRecordId
  entityType String?     // "CertificationRecord" | "ComplianceRequirement"
  meta       Json?       // arbitrary extra data
  ipAddress  String?
  createdAt  DateTime    @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  actor  User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════════════════════════
// Phase 11 — Automation & Notifications
// ══════════════════════════════════════════════════════════════════════════════

enum NotificationType {
  COURSE_ASSIGNED
  COURSE_DUE_SOON
  COURSE_OVERDUE
  COURSE_COMPLETED
  CERT_EXPIRING
  CERT_EXPIRED
  CERT_ISSUED
  ASSESSMENT_ASSIGNED
  ASSESSMENT_DUE
  BROADCAST
  SYSTEM
}

// ── In-app Notification ───────────────────────────────────────────────────────
model Notification {
  id         String           @id @default(cuid())
  tenantId   String
  userId     String
  type       NotificationType
  title      String
  body       String           @db.Text
  link       String?          // deeplink URL within the LMS
  isRead     Boolean          @default(false)
  readAt     DateTime?
  meta       Json?            // arbitrary extra data (entityId, entityType, etc.)
  createdAt  DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

// ── Notification Preferences ──────────────────────────────────────────────────
model NotificationPreference {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  inApp    Boolean          @default(true)
  email    Boolean          @default(true)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@map("notification_preferences")
}

// ── Job Schedule (recurring job definitions) ────────────────────────────────
// Stores cron-managed recurring assignment rules (e.g. annual OSHA refresh)
model JobSchedule {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  jobType     String    // "cert_expiry_scan" | "overdue_escalation" | "recurrent_assignment"
  cronExpr    String    // cron expression e.g. "0 6 * * *"
  payload     Json?
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("job_schedules")
}
