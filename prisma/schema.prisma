// Kirby Learning Academy — Prisma Schema
// Phase 4: Course publishing, versions, catalog
// Run: npx prisma migrate dev --name phase4_courses

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7+)
}

// ── Tenants (business units / multi-tenancy) ────────────────────────────────
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique  // used in subdomain / header routing
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  businessUnits BusinessUnit[]
  departments Department[]
  locations   Location[]
  jobTitles   JobTitle[]
  hrisSyncLogs HrisSyncLog[]
  courses     Course[]

  @@map("tenants")
}

// ── Org Structure ────────────────────────────────────────────────────────────
model BusinessUnit {
  id          String   @id @default(cuid())
  name        String
  code        String?
  tenantId    String
  parentId    String?  // self-referential for nested business units
  sortOrder   Int      @default(0)
  hrisId      String?  // external HRIS system identifier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  parent      BusinessUnit? @relation("BusinessUnitHierarchy", fields: [parentId], references: [id])
  children    BusinessUnit[] @relation("BusinessUnitHierarchy")
  departments Department[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@map("business_units")
}

model Department {
  id             String   @id @default(cuid())
  name           String
  code           String?
  tenantId       String
  businessUnitId String?
  sortOrder      Int      @default(0)
  hrisId         String?  // external HRIS system identifier
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  users        User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([businessUnitId])
  @@map("departments")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String?
  country   String   @default("US")
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  users     User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("locations")
}

model JobTitle {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  users     User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("job_titles")
}

// ── Users ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  displayName   String?
  avatarUrl     String?
  passwordHash  String?   // null for SSO-only accounts
  isActive      Boolean   @default(true)
  isContractor  Boolean   @default(false)  // contractor / external flag
  hireDate      DateTime?
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  locationId    String?
  location      Location?   @relation(fields: [locationId], references: [id])
  jobTitleId    String?
  jobTitle      JobTitle?   @relation(fields: [jobTitleId], references: [id])
  businessUnitId String?
  businessUnit  BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  // HRIS sync fields
  hrisId        String?   // identifier in the HRIS system
  hrisSource    String?   // "workday" | "successfactors" | "csv"
  lastHrisSyncAt DateTime?
  terminatedAt  DateTime? // set on HRIS termination; triggers deactivation

  roles         UserRole[]
  sessions      Session[]
  accounts      Account[]  // OAuth / SAML providers (NextAuth)
  passwordResets PasswordResetToken[]
  createdCourses Course[]        @relation("CourseCreator")
  uploadedVersions CourseVersion[] @relation("VersionUploader")

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ── Roles & Permissions ──────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  name        String   @unique  // SUPER_ADMIN | TENANT_ADMIN | COMPLIANCE_OFFICER | MANAGER | INSTRUCTOR | EMPLOYEE | CONTRACTOR
  description String?
  createdAt   DateTime @default(now())

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

// ── Sessions (NextAuth database sessions) ───────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ── OAuth / SAML Accounts (NextAuth) ────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // "oauth" | "saml" | "credentials"
  provider          String  // "azure-ad" | "okta" | "credentials"
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ── Verification Tokens (email / password reset) ────────────────────────────
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Password Reset Tokens ────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ── HRIS Sync Logs ───────────────────────────────────────────────────────────
model HrisSyncLog {
  id          String   @id @default(cuid())
  tenantId    String
  source      String   // "workday" | "successfactors" | "csv"
  status      String   // "running" | "success" | "failed"
  recordsIn   Int      @default(0)
  created     Int      @default(0)
  updated     Int      @default(0)
  deactivated Int      @default(0)
  errors      Json?    // array of error messages
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([startedAt])
  @@map("hris_sync_logs")
}

// ── Course Publishing ────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Course {
  id                   String       @id @default(cuid())
  tenantId             String
  title                String
  description          String?      @db.Text
  category             String?
  objectives           String[]     // auto-populated from manifest
  duration             Int?         // estimated minutes
  thumbnailUrl         String?
  targetAudience       String?      @db.Text
  complianceTags       String[]     // e.g. ["OSHA","USCG","Maritime"]
  isContractorVisible  Boolean      @default(false)
  status               CourseStatus @default(DRAFT)
  activeVersionId      String?      @unique
  createdById          String
  archivedAt           DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  createdBy     User            @relation("CourseCreator", fields: [createdById], references: [id])
  activeVersion CourseVersion?  @relation("ActiveVersion", fields: [activeVersionId], references: [id])
  versions      CourseVersion[] @relation("CourseVersions")
  tags          CourseTag[]
  languages     CourseLanguage[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("courses")
}

model CourseVersion {
  id               String   @id @default(cuid())
  courseId         String
  versionNumber    Int      // 1, 2, 3, ...
  s3Prefix         String   // e.g. "courses/clxxx/v1/"
  manifestSnapshot Json     // parsed _course_manifest.json at upload time
  originalFileName String?
  fileSizeBytes    Int?
  uploadedById     String
  uploadedAt       DateTime @default(now())

  course       Course   @relation("CourseVersions", fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("VersionUploader", fields: [uploadedById], references: [id])
  activeFor    Course?  @relation("ActiveVersion")

  @@unique([courseId, versionNumber])
  @@index([courseId])
  @@map("course_versions")
}

model CourseTag {
  id       String @id @default(cuid())
  courseId String
  tag      String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, tag])
  @@index([courseId])
  @@map("course_tags")
}

model CourseLanguage {
  id        String  @id @default(cuid())
  courseId  String
  language  String  // ISO 639-1 e.g. "en", "es"
  isDefault Boolean @default(false)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, language])
  @@map("course_languages")
}

